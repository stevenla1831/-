rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // users/{uid}         – role: admin | store | user
    // stores/{docId}      – id, name, description, createdAt
    // coupons/{docId}     – storeId, code, type, status: available|assigned|used
    //                       userId?, assignedAt?, usedAt?
    // drawRecords/{docId} – userId, storeId, couponId, week, timestamp, source
    // weeklyDraws/{id}    – userId, storeId, week, couponId, drawnAt
    //                       docId = "{userId}_{storeId}_{YYYY-WW}"
    // ===============================================================

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && (
        userDoc().role == 'admin' ||
        (request.auth.token.email == "stevenla1831@gmail.com" &&
         request.auth.token.email_verified == true)
      );
    }

    function isStore() {
      return isAuth() && userDoc().role == 'store';
    }

    function isStoreOwner(storeId) {
      return isStore() && storeId in userDoc().assignedStores;
    }

    // ── users ────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone can read their own doc; admin can read all
      allow read: if isAuth() && (uid() == userId || isAdmin());
      // Users create their own doc on first login (role forced to 'user')
      allow create: if isAuth() && uid() == userId &&
                       request.resource.data.role == 'user';
      // Owner can update own non-role fields; admin can update anything
      allow update: if isAuth() && (
                       (uid() == userId && request.resource.data.role == resource.data.role) ||
                       isAdmin()
                    );
    }

    // ── stores ───────────────────────────────────────────────────
    match /stores/{storeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── coupons ──────────────────────────────────────────────────
    match /coupons/{couponId} {
      // Owners see their own coupons; store owners see their store's coupons; admin sees all
      allow read: if isAuth() && (
                     isAdmin() ||
                     isStoreOwner(resource.data.storeId) ||
                     (resource.data.status != 'available' && uid() == resource.data.userId)
                  );
      // Admin or store owner can create coupons for their store
      allow create: if isAdmin() ||
                       (isAuth() && isStoreOwner(request.resource.data.storeId));
      // Allow update by:
      //   - admin (any update)
      //   - store owner: mark assigned→used
      //   - authenticated user: claim available coupon (status available→assigned, own uid)
      allow update: if isAdmin() ||
                       isStoreOwner(resource.data.storeId) ||
                       (isAuth() &&
                        resource.data.status == 'available' &&
                        request.resource.data.status == 'assigned' &&
                        request.resource.data.userId == uid());
    }

    // ── drawRecords ──────────────────────────────────────────────
    match /drawRecords/{recordId} {
      allow read: if isAuth() && (
                     isAdmin() ||
                     isStoreOwner(resource.data.storeId) ||
                     uid() == resource.data.userId
                  );
      allow create: if isAuth() && (
                       uid() == request.resource.data.userId ||
                       isAdmin() ||
                       isStoreOwner(request.resource.data.storeId)
                    );
    }

    // ── weeklyDraws ──────────────────────────────────────────────
    // docId = "{userId}_{storeId}_{YYYY-WW}"
    match /weeklyDraws/{drawId} {
      allow read: if isAuth() && (
                     isAdmin() ||
                     uid() == resource.data.userId
                  );
      // Created atomically during the draw transaction
      allow create: if isAuth() && uid() == request.resource.data.userId;
      // No updates — draw records are immutable
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── announcements ────────────────────────────────────────────
    match /announcements/{announcementId} {
      // All authenticated users can read active announcements
      allow read: if isAuth();
      // Only admins can create, update, delete
      allow write: if isAdmin();
    }
  }
}
